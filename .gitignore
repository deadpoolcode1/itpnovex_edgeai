# Local-only notes and secrets
CLAUDE.md

# Personal drafts
email_to_sylvain.md

# Captured media and diagnostic artifacts — regenerable, not worth versioning
captures/*
*.h264
*.mp4
*.jpg
*.jpeg
*.png
# Test images for the algorithm regression group ARE tracked — small, deterministic, NASA-PD + scikit-image samples
!tests/images/*.jpg
# (PDFs in repo root are reference docs and ARE tracked — see !*.pdf below)

# Build outputs (catch-all)
build/
out/
*.elf
*.bin
*.hex
*.map
*.o
*.obj
*.d
*.a
*.list
*.su
*.cyclo

# CubeIDE per-project Release/Debug directories under the vendor BSP
vendor/n6cam.core.bsp/Firmware/STM32CubeIDE/*/Release/
vendor/n6cam.core.bsp/Firmware/STM32CubeIDE/*/Debug/

# But keep the vendor binary blobs the build needs (can't regenerate without retraining model / vendor WiFi firmware)
!vendor/n6cam.core.bsp/Firmware/Model/network_data.hex
!vendor/n6cam.core.bsp/Firmware/Middlewares/Third_Party/WHD/binaries/*.bin

# Bulky vendor reference docs (duplicates of online HTML reference manual)
*.chm

# Other vendor / SDK downloads (still ignored — only the N6Cam BSP is vendored in)
sdk/
third_party/
.deps/

# Logs and transient runtime files
*.log
*.tmp
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
.env
.venv/
venv/

# Node
node_modules/

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Keep the datasheet PDFs in the repo root
!*.pdf

# Ultralytics auto-downloaded weights — never commit
yolov8n.pt
yolov8n_saved_model/

# Architecture / process diagrams are sources of record — keep tracked
!docs/diagrams/*.png
# Live-detection capture used in the milestone email — keep tracked
!captures/n6cam_live_detection_*.jpg

# Soak HTML/PDF artifacts are large + regenerable; keep only the CSV summaries
results/soak-*/*.html
results/soak-*/*.pdf
results/soak-*/*_artifacts/

# LibreOffice lock files
.~lock*#
